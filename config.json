{
  "port": 8443,
  "default_ssl": true,
  "default_crt": "server.crt",
  "default_key": "server.key",
  "allowed_ips": ["192.168.1.0/24", "10.0.0.1"],
  "denied_ips": ["1.2.3.4"],
  "vhosts": [
    {
      "hostname": "api.example.com",
      "upstream_url": "https://internal-api.example.com",
      "jwt_secret": "your-jwt-secret-here",
      "ssl_enabled": true,
      "ssl_cert": "api.example.com.crt",
      "ssl_key": "api.example.com.key",
      "insecure_tls": true
    },
    {
      "hostname": "public.example.com",
      "upstream_url": "http://internal-public.example.com",
      "jwt_secret": "",
      "ssl_enabled": true,
      "ssl_cert": "public.example.com.crt",
      "ssl_key": "public.example.com.key",
      "insecure_tls": false
    }
  ]
}